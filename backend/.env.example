# Copy to .env and fill in values. Loaded by godotenv at server start.

# Auth — set to bypass x-token-user-email proxy header in local dev
DEBUG_AUTH_EMAIL=

# BMM (Auth0 client credentials grant)
BMM_AUTH0_BASE_URL=
BMM_CLIENT_ID=
BMM_CLIENT_SECRET=
BMM_AUDIENCE=
BMM_BASE_URL=
BMM_INT_BASE_URL=
# Optional: skips the Auth0 token exchange entirely
BMM_DEBUG_TOKEN=

# Temporal
TEMPORAL_HOST_PORT=localhost:7233
TEMPORAL_NAMESPACE=default
# Web UI base for the jobs "See in Temporal" link. Optional locally (a localhost
# gRPC host auto-resolves to http://localhost:8233); set explicitly in prod.
# TEMPORAL_UI_URL=https://temporal.example.com
QUEUE=

# Vidispine / Cantemo
VIDISPINE_BASE_URL=
VIDISPINE_USERNAME=
VIDISPINE_PASSWORD=
CANTEMO_URL=
CANTEMO_TOKEN=

# Filesystem paths
TEMP_PATH=
STATIC_FILE_PATH=
CONFIG_ROOT=
OVERLAYS_DIR=
SUBTITLE_STYLES_DIR=

# Misc
DEBUG=
